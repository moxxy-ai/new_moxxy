{
  "name": "@moxxy/plugin-channel-http",
  "version": "0.0.0",
  "description": "Request-response HTTP channel for moxxy. POST /v1/turn drives one turn synchronously; POST /v1/turn/stream returns Server-Sent Events. Bearer-token auth + allow-list permission flow (no human in the loop).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "moxxy": { "plugin": { "entry": "./dist/index.js", "kind": "channel" } },
  "dependencies": {
    "@moxxy/core": "workspace:*",
    "@moxxy/sdk": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@moxxy/mode-tool-use": "workspace:*",
    "@moxxy/runner": "workspace:*",
    "@moxxy/testing": "workspace:*",
    "@moxxy/tools-builtin": "workspace:*",
    "@moxxy/tsconfig": "workspace:*",
    "@moxxy/vitest-preset": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
