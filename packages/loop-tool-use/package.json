{
  "name": "@moxxy/loop-tool-use",
  "version": "0.0.0",
  "description": "Default tool-use loop strategy for moxxy (Claude Code-style).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "moxxy": {
    "plugin": {
      "entry": "./dist/index.js",
      "kind": "loop"
    }
  },
  "dependencies": {
    "@moxxy/sdk": "workspace:*"
  },
  "devDependencies": {
    "@moxxy/core": "workspace:*",
    "@moxxy/testing": "workspace:*",
    "@moxxy/tsconfig": "workspace:*",
    "@moxxy/vitest-preset": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "zod": "^3.24.0"
  }
}
