{
  "name": "@moxxy/plugin-cli",
  "private": true,
  "version": "0.0.1",
  "description": "Ink-based interactive TUI components + interactive PermissionResolver for moxxy.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "moxxy": {
    "plugin": {
      "entry": "./dist/index.js",
      "kind": "cli"
    }
  },
  "dependencies": {
    "@moxxy/chat-model": "workspace:*",
    "@moxxy/core": "workspace:*",
    "@moxxy/plugin-mcp": "workspace:*",
    "@moxxy/sdk": "workspace:*",
    "ink": "catalog:",
    "react": "catalog:"
  },
  "devDependencies": {
    "@moxxy/tsconfig": "workspace:*",
    "@moxxy/vitest-preset": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "yaml": "^2.6.0"
  }
}
