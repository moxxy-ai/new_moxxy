{
  "name": "@moxxy/desktop-ipc-contract",
  "private": true,
  "version": "0.0.1",
  "description": "The single source of truth for the moxxy desktop IPC boundary: channel names, request/response types, the window.moxxy surface, and Zod schemas for runtime payload validation. Shared by the Electron main process, the preload bridge, and the renderer.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@moxxy/sdk": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@moxxy/tsconfig": "workspace:*",
    "@moxxy/vitest-preset": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
