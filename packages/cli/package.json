{
  "name": "@moxxy/cli",
  "version": "0.0.0",
  "description": "moxxy command-line binary. Subcommand dispatcher consuming the moxxy SDK.",
  "type": "module",
  "main": "./dist/bin.js",
  "bin": {
    "moxxy": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsx scripts/gen-requirements.mts && tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "start": "node ./dist/bin.js"
  },
  "dependencies": {
    "@moxxy/sdk": "workspace:*",
    "zod": "catalog:"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.0.0",
    "keytar": "^7.9.0",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@clack/prompts": "catalog:",
    "@moxxy/compactor-summarize": "workspace:*",
    "@moxxy/config": "workspace:*",
    "@moxxy/core": "workspace:*",
    "@moxxy/isolator-subprocess": "workspace:*",
    "@moxxy/isolator-wasm": "workspace:*",
    "@moxxy/isolator-worker": "workspace:*",
    "@moxxy/mode-bmad": "workspace:*",
    "@moxxy/mode-deep-research": "workspace:*",
    "@moxxy/mode-developer": "workspace:*",
    "@moxxy/mode-plan-execute": "workspace:*",
    "@moxxy/mode-tool-use": "workspace:*",
    "@moxxy/plugin-browser": "workspace:*",
    "@moxxy/plugin-channel-http": "workspace:*",
    "@moxxy/plugin-cli": "workspace:*",
    "@moxxy/plugin-commands": "workspace:*",
    "@moxxy/plugin-computer-control": "workspace:*",
    "@moxxy/plugin-embeddings-openai": "workspace:*",
    "@moxxy/plugin-embeddings-transformers": "workspace:*",
    "@moxxy/plugin-mcp": "workspace:*",
    "@moxxy/plugin-memory": "workspace:*",
    "@moxxy/plugin-oauth": "workspace:*",
    "@moxxy/plugin-plugins-admin": "workspace:*",
    "@moxxy/plugin-provider-admin": "workspace:*",
    "@moxxy/plugin-provider-anthropic": "workspace:*",
    "@moxxy/plugin-provider-openai": "workspace:*",
    "@moxxy/plugin-provider-openai-codex": "workspace:*",
    "@moxxy/plugin-scheduler": "workspace:*",
    "@moxxy/plugin-security": "workspace:*",
    "@moxxy/plugin-self-update": "workspace:*",
    "@moxxy/plugin-stt-whisper": "workspace:*",
    "@moxxy/plugin-stt-whisper-codex": "workspace:*",
    "@moxxy/plugin-subagents": "workspace:*",
    "@moxxy/plugin-telegram": "workspace:*",
    "@moxxy/plugin-vault": "workspace:*",
    "@moxxy/plugin-webhooks": "workspace:*",
    "@moxxy/runner": "workspace:*",
    "@moxxy/skills-builtin": "workspace:*",
    "@moxxy/tools-builtin": "workspace:*",
    "@moxxy/tsconfig": "workspace:*",
    "@moxxy/vitest-preset": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "ink": "catalog:",
    "react": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
