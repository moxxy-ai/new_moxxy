{
  "name": "@moxxy/sdk",
  "version": "0.1.0",
  "description": "Typed public surface for the moxxy framework: event types, define* factories, lifecycle hook signatures.",
  "keywords": [
    "moxxy",
    "agent",
    "agents",
    "agent-framework",
    "ai",
    "llm",
    "anthropic",
    "claude",
    "openai",
    "gpt",
    "plugin",
    "plugin-sdk",
    "sdk",
    "tools",
    "tool-use",
    "mcp",
    "typescript",
    "zero-deps"
  ],
  "homepage": "https://moxxy.ai",
  "bugs": {
    "url": "https://github.com/moxxy-ai/new_moxxy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moxxy-ai/new_moxxy.git",
    "directory": "packages/sdk"
  },
  "author": "Michal Makowski <michal.makowski97@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.10.0"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@moxxy/tsconfig": "workspace:*",
    "@moxxy/vitest-preset": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
