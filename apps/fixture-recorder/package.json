{
  "name": "fixture-recorder",
  "version": "0.0.0",
  "private": true,
  "description": "Record real Anthropic interactions into JSONL fixtures for the moxxy test harness.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": { "moxxy-record": "./dist/index.js" },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "node ./dist/index.js",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@moxxy/core": "workspace:*",
    "@moxxy/mode-tool-use": "workspace:*",
    "@moxxy/plugin-provider-anthropic": "workspace:*",
    "@moxxy/sdk": "workspace:*",
    "@moxxy/testing": "workspace:*",
    "@moxxy/tools-builtin": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@moxxy/tsconfig": "workspace:*",
    "@moxxy/vitest-preset": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
