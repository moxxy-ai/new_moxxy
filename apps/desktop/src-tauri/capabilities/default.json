{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the desktop main window.",
  "windows": ["main", "session-*", "quick-prompt"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "opener:default",
    "dialog:allow-open",
    "fs:default",
    "store:default",
    "global-shortcut:default"
  ]
}
