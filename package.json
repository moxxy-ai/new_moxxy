{
  "name": "moxxy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Block-based, modular agentic loop framework.",
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --concurrency=1",
    "check:deps": "depcruise --config .dependency-cruiser.cjs packages apps/desktop/electron",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@moxxy/config": "workspace:*",
    "@types/node": "catalog:",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tsx": "catalog:",
    "turbo": "^2.5.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "electron",
      "electron-winstaller"
    ]
  }
}
